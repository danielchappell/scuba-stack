  "homeDir": ".codex",
  "rootInstructionFile": "AGENTS.md",
  "pointerFile": "scuba.md",
  "pointerImportLine": "",
  "rootMode": "managed-block",
  "legacyImportLines": ["@~/.codex/scuba.md"],
  "agentFormat": "codex-toml",
  "skillDir": ".agents/skills",
  "agentDir": "agents",
  "hookDir": "hooks",
  "install": {
    "skillDir": "../.agents/skills",
    "agentDir": "agents",
    "hookDir": "hooks"
  },
  "worktreeSegment": ".codex/worktrees",
  "terms": {
    "rootGuidanceFile": "AGENTS.md",
    "rootGuidancePath": "~/.codex/AGENTS.md",
    "userScopeHome": "~/.codex",
    "fileEditTools": "Codex file-edit tools",
    "highJudgmentModel": "GPT-5.5",
    "externalReviewerExample": "Codex",
    "externalReviewerRetriggerExample": "comment \"@codex review\" on the PR",
    "externalReviewerNonMainDefault": "Codex does by default"
  },
  "models": {
    "lead": "inherit",
    "high_judgment": "gpt-5.5"
  },
  "reasoning": {
    "high_judgment": "high"
  },
  "toolProfiles": {
    "design": "default",
    "read_run": "explorer",
    "write_notes": "worker",
    "write_notes_web": "worker",
    "write_brief": "worker",
    "code_writer": "worker"
  },
  "hooks": {
    "scuba-guard": {
      "install": true,
      "event": "PreToolUse",
      "matcher": "Bash|apply_patch|Edit|Write",
