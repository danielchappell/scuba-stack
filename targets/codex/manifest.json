      "configFile": "hooks.json",
      "configFormat": "codex-hooks-json",
      "status": "installed-pending-trust",
      "reason": "Codex hook adapter is installed through hooks.json, but Codex requires the user to review and trust non-managed command hooks with /hooks before enforcement is operational."
